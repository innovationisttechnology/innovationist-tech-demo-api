# Application
APP_NAME="Innovationist Tech Demo API"
APP_VERSION="1.0.0"
ENVIRONMENT="development"
PORT=8181

# Comma-separated origins allowed to call the API (the demo UI).
# Optional — if unset, defaults to http://localhost:3001 in development and
# https://demo.innovationisttech.com in production. Set explicitly to override.
# Origins are scheme+host+port only (no trailing slash/path).
# CORS_ORIGINS="http://localhost:3001,https://demo.innovationisttech.com"

# MongoDB — optional. Set to enable database features.
# MONGO_URI="mongodb://localhost:27017"
# MONGO_DB_NAME="innovationist_demo"

# docker-compose only: root credentials for the bundled mongo/mongo-express.
# Defaults to admin/adminpassword if unset.
# MONGO_ROOT_USER="admin"
# MONGO_ROOT_PASSWORD="adminpassword"
